{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.dotfiles/agents/AGENTS.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "share": "manual",
  "autoupdate": true,
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "color": "#47bac0"
    },
    "build": {
      "model": "openai/gpt-5.4",
      "color": "#e4609b"
    },
    "research": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "color": "#00EC6E",
      "mode": "subagent",
      "description": "Does deep research on codebases and answers questions without making changes",
      "prompt": "You are a read-only deep research agent. You must never modify files, run destructive commands, or make changes to the codebase.",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  },
  "mcp": {
    "liege": {
      "type": "local",
      "command": [
        "/Users/jesseleite/.dotfiles/mcp/liege/liege"
      ],
      "enabled": true
    },
    "pretty_table": {
      "type": "local",
      "command": [
        "/Users/jesseleite/.dotfiles/mcp/pretty_table/pretty_table"
      ],
      "enabled": true
    }
  }
}
